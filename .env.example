# Настройки веб-панели
PANEL_PORT=2053
PANEL_SECRET_PATH=ui

# Учетные данные по умолчанию (при первом запуске будут случайно перегенерированы)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Токен для интеграции с контроллером
API_TOKEN=default_api_token

# Лимит IPS (автоблокировка при обнаружении сканирования портов)
# Количество уникальных IP-адресов назначения за 10 секунд
IPS_PORT_SCAN_LIMIT=200

# Настройки Telegram (заполните для работы Mini App)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=

# Настройки СУБД PostgreSQL (Параметры безопасности)
POSTGRES_DB=spectre_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=generate_secure_random_password

DB_APP_USER=spectre_app
DB_APP_PASSWORD=generate_secure_random_password

# Строки подключения к БД (Администратор DDL / Приложение DML)
# Если оставить пустыми, приложение автоматически использует SQLite (panel.db)
DATABASE_ADMIN_URL=postgresql://postgres:postgres_password@127.0.0.1:5432/spectre_db
DATABASE_URL=postgresql://spectre_app:app_password@127.0.0.1:5432/spectre_db
